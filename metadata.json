{
  "name": "puppet-networkmanager",
  "version": "0.1.0",
  "author": "voxpupuli",
  "summary": "Manages NetworkManager and its configuration",
  "license": "AGPL-3.0",
  "source": "https://github.com/voxpupuli/puppet-networkmanager",
  "dependencies": [
    {
      "name": "puppet/extlib",
      "version_requirement": ">= 7.5.1 < 8.0.0"
    }
  ],
  "operatingsystem_support": [
    {
      "operatingsystem": "CentOS",
      "operatingsystemrelease": [
        "9",
        "10"
      ]
    },
    {
      "operatingsystem": "RedHat",
      "operatingsystemrelease": [
        "9",
        "10"
      ]
    },
    {
      "operatingsystem": "Rocky",
      "operatingsystemrelease": [
        "9",
        "10"
      ]
    },
    {
      "operatingsystem": "AlmaLinux",
      "operatingsystemrelease": [
        "9",
        "10"
      ]
    }
  ],
  "requirements": [
    {
      "name": "puppet",
      "version_requirement": ">= 7.24 < 9.0.0"
    },
    {
      "name": "openvox",
      "version_requirement": ">= 7.9.0 < 9.0.0"
    }
  ]
}
