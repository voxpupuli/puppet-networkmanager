{
  "name": "puppet-networkmanager",
  "version": "0.1.0",
  "author": "Vox Pupuli",
  "summary": "Manage NetworkManager and Interfaces",
  "license": "AGPL-3.0",
  "source": "https://github.com/voxpupuli/puppet-networkmanager",
  "project_page": "https://github.com/voxpupuli/puppet-networkmanager",
